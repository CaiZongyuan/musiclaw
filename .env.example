# Required for server-side loaders and server functions.
# Use an absolute URL for your standalone Netease API service.
NETEASE_API_URL=http://127.0.0.1:3002

# Optional client-side override. If omitted, the app uses NETEASE_API_URL on the server.
# VITE_NETEASE_API_URL=http://127.0.0.1:3001

# Optional override for the realIP parameter sent to Netease API.
# VITE_REAL_IP=211.161.244.70

# Optional Last.fm integration for /lastfm/callback.
# LASTFM_API_KEY=your_lastfm_api_key
# LASTFM_API_SHARED_SECRET=your_lastfm_api_shared_secret
